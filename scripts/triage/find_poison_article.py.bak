"""Find the poison article(s) crashing bge-m3 /api/embed for a given run.

Usage (from project root):
    python scripts/triage/find_poison_article.py
    python scripts/triage/find_poison_article.py run_20260528

Adjusts to the real schema by first printing the table + column names so
we stop guessing. Then runs the oversized-input and empty-lead probes.
"""

from __future__ import annotations

import sys

import duckdb

RUN_ID = sys.argv[1] if len(sys.argv) > 1 else "run_20260528"
DB_PATH = "data/musahit.duckdb"


def main() -> None:
    conn = duckdb.connect(DB_PATH, read_only=True)

    print("=== TABLES ===")
    tables = conn.execute("SHOW TABLES").fetchall()
    for t in tables:
        print(" ", t[0])

    # Find the articles-like table and its columns. The schema uses some
    # name we have not confirmed; inspect anything that looks right.
    print("\n=== COLUMNS per candidate table ===")
    candidates = [
        t[0]
        for t in tables
        if any(k in t[0].lower() for k in ("article", "item", "doc", "story"))
    ]
    if not candidates:
        candidates = [t[0] for t in tables]
    for tbl in candidates:
        cols = conn.execute(f"PRAGMA table_info('{tbl}')").fetchall()
        colnames = [c[1] for c in cols]
        print(f"  {tbl}: {colnames}")

    # Best-effort probe. We try common column names; if they do not exist
    # the except prints what went wrong so we can adjust.
    print("\n=== OVERSIZED INPUT PROBE (top 10 by title+lead length) ===")
    for art_tbl in candidates:
        try:
            rows = conn.execute(
                f"""
                SELECT a.id,
                       LENGTH(COALESCE(a.title, '')) + LENGTH(COALESCE(a.lead, '')) AS n,
                       a.word_count,
                       SUBSTRING(COALESCE(a.title, ''), 1, 90) AS title_head
                FROM {art_tbl} a
                JOIN ingest_log l ON l.source_id = a.source_id
                WHERE l.run_id = ?
                ORDER BY n DESC
                LIMIT 10
                """,
                [RUN_ID],
            ).fetchall()
            print(f"  (via table '{art_tbl}')")
            for r in rows:
                print(f"  len={r[1]:>7}  wc={r[2]:>5}  id={r[3]!r}  {r[3] if False else ''}")
                print(f"           title: {r[4]}")
            break
        except Exception as exc:  # noqa: BLE001
            print(f"  table '{art_tbl}' probe failed: {type(exc).__name__}: {exc}")

    print("\n=== EMPTY-LEAD PROBE (word_count>=10 but empty lead) ===")
    for art_tbl in candidates:
        try:
            rows = conn.execute(
                f"""
                SELECT a.id, a.word_count,
                       SUBSTRING(COALESCE(a.title, ''), 1, 90) AS title_head
                FROM {art_tbl} a
                JOIN ingest_log l ON l.source_id = a.source_id
                WHERE l.run_id = ?
                  AND a.word_count >= 10
                  AND (a.lead IS NULL OR TRIM(a.lead) = '')
                LIMIT 10
                """,
                [RUN_ID],
            ).fetchall()
            print(f"  (via table '{art_tbl}') {len(rows)} rows")
            for r in rows:
                print(f"  wc={r[1]:>5}  id={r[0]!r}  title: {r[2]}")
            break
        except Exception as exc:  # noqa: BLE001
            print(f"  table '{art_tbl}' probe failed: {type(exc).__name__}: {exc}")

    conn.close()


if __name__ == "__main__":
    main()
